generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int             @id @default(autoincrement())
  name           String
  bio            String?
  githubUsername String          @unique
  avatarUrl      String?
  followers      Int             @default(0)
  location       String?
  fetchedAt      DateTime        @updatedAt
  contributions  Contribution[]
  languages      LanguageStats[]
  repos          Repo[]
}

model Repo {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  forks       Int     @default(0)
  stars       Int     @default(0)
  url         String
  is_pinned   Boolean @default(false)
  language    String?
  userId      Int
  user        User    @relation(fields: [userId], references: [id] ,onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

model Contribution {
  id          Int      @id @default(autoincrement())
  date        DateTime
  commitCount Int      @default(0)
  userId      Int
  user        User     @relation(fields: [userId], references: [id],onDelete: Cascade)

  @@index([userId])
  @@unique([userId,date])
}

model LanguageStats {
  id      Int    @id @default(autoincrement())
  name    String
  percent Float
  color   String
  userId  Int
  user    User   @relation(fields: [userId], references: [id] ,onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}
